{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://guitar-tutor.local/schemas/coco.schema.json",
  "title": "COCO-style hand-keypoints file (21 MediaPipe keypoints)",
  "$comment": "Canonical source of truth is the Zod schema at apps/annotation-tool/src/schemas/coco.ts + handKeypoints.ts (WP-6, §13 of the stack plan, ADR-006 keypoint set). Hand-written mirror, kept in sync by hand.",
  "type": "object",
  "required": ["images", "annotations", "categories"],
  "additionalProperties": false,
  "properties": {
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "file_name", "width", "height", "frame_index", "t"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "integer", "minimum": 0 },
          "file_name": { "type": "string", "minLength": 1 },
          "width": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 },
          "frame_index": { "type": "integer", "minimum": 0 },
          "t": { "type": "number", "minimum": 0, "description": "seconds, synced to the clip's video/audio clock" }
        }
      }
    },
    "annotations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "image_id", "category_id", "keypoints", "num_keypoints"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "integer", "minimum": 0 },
          "image_id": { "type": "integer", "minimum": 0 },
          "category_id": { "const": 1 },
          "keypoints": {
            "type": "array",
            "description": "flattened [x,y,v] * 21 keypoints; v: 0=not labeled, 1=labeled-not-visible, 2=labeled-visible (COCO convention)",
            "items": { "type": "number" },
            "minItems": 63,
            "maxItems": 63
          },
          "num_keypoints": { "type": "integer", "minimum": 0, "maximum": 21 }
        }
      }
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "keypoints"],
        "additionalProperties": false,
        "properties": {
          "id": { "const": 1 },
          "name": { "const": "hand" },
          "keypoints": {
            "type": "array",
            "minItems": 21,
            "maxItems": 21,
            "items": { "type": "string" },
            "description": "MediaPipe HandLandmarker order: wrist, thumb_cmc..pinky_tip"
          }
        }
      }
    }
  }
}
